# ── 더블디럭스 환경변수 예시 ──────────────────────────────
# 이 파일을 복사해서 `.env.local` 로 저장하면 됩니다.
# 기본값(injected/MetaMask)만으로도 동작하므로 아래는 모두 선택사항입니다.

# (선택) WalletConnect Project ID — 모바일 지갑/QR 연결을 추가하려면 필요
# https://cloud.walletconnect.com 에서 무료 발급
NEXT_PUBLIC_WC_PROJECT_ID=

# (선택) Sepolia RPC URL — 비워두면 공개 RPC를 사용합니다
# 예: Alchemy/Infura
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# (선택) 플랫폼/데모 판매자 기본 수취 주소 (목업용)
NEXT_PUBLIC_DEMO_SELLER_ADDRESS=
