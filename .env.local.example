# --- Wallet connection -----------------------------------------------------
# Free project id from https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# --- Where customer payments land ------------------------------------------
NEXT_PUBLIC_MERCHANT_ADDRESS=0xYourMerchantWalletHere

# --- Contract addresses ----------------------------------------------------
# Defaults in lib/payment.ts are Base MAINNET. Override here for Base Sepolia
# testnet (recommended for development). Fill these with the testnet
# deployments you intend to use:
# NEXT_PUBLIC_SWAP_ROUTER=0x...
# NEXT_PUBLIC_QUOTER=0x...
# NEXT_PUBLIC_BTC_TOKEN=0x...        # WBTC / cbBTC (8 decimals)
# NEXT_PUBLIC_WETH=0x...
# NEXT_PUBLIC_USDC=0x...
